#!/bin/bash

# Pull from every downstream branch into `dev`.
#
# Under the release pipeline (dev → pre-staging → staging → main),
# `dev` is the source of all changes; the downstream branches only
# accumulate commits via auto-promotion. So in normal operation
# this script is a no-op — but kept defensive so a hand-applied
# fix on any downstream branch is reconciled back into `dev`
# automatically instead of silently drifting.
#
# NOOP if nothing to merge.

# Exit immediately if a command exits with a non-zero status
set -e

git fetch origin

# Update each downstream branch's local tracking ref so the merge-base
# lookups below see the latest remote state.
for b in main pre-staging staging; do
  if git show-ref --verify --quiet "refs/heads/$b"; then
    git checkout "$b"
    git pull --ff-only origin "$b" || true
  fi
done

git checkout dev

# Merge each downstream branch into dev in order. Order matters:
# main is the "oldest" / most-stable, then staging, then pre-staging.
# By merging from oldest to newest, conflict resolution is layered
# the same way a human would do it.
for b in main staging pre-staging; do
  # Skip silently if the branch doesn't exist (e.g. first-run before
  # the pipeline branches were created).
  if ! git show-ref --verify --quiet "refs/remotes/origin/$b"; then
    continue
  fi
  merge_base=$(git merge-base dev "origin/$b")
  if git diff --quiet "$merge_base" "origin/$b"; then
    echo "No changes to merge from $b to dev."
    continue
  fi
  if git merge --no-commit --no-ff "origin/$b"; then
    if git diff-index --quiet HEAD --; then
      echo "No changes to merge from $b to dev."
      git merge --abort
    else
      git commit -m "Merged $b into dev"
      echo "Merged $b into dev."
    fi
  else
    echo "Merge of $b into dev failed due to conflicts. Next steps:"
    echo "1. Identify conflicts with 'git status'."
    echo "2. Resolve manually by editing the conflicted files."
    echo "3. Mark as resolved using 'git add <file>'."
    echo "4. Complete merge with 'git commit'."
    exit 1
  fi
done
