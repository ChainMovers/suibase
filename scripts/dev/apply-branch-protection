#!/bin/bash

# One-time setup: apply branch protection rules on main / staging / pre-staging
# to enforce the release pipeline. Idempotent — safe to re-run.
#
# Pre-requisites:
#   * The branches pre-staging and staging must already exist on origin.
#   * The "PR Gate / enforce-pipeline-order" check must have run at least
#     once (so GitHub recognises it as a registered status check). The
#     first time you run this script on a fresh repo, you may need to
#     open a PR (any PR — even a no-op) to seed the check name. After
#     that this script is one-shot.
#
# Usage:
#   ~/suibase/scripts/dev/apply-branch-protection
#
# Requires `gh` authenticated as a user with admin on the repo.

set -e

REPO="ChainMovers/suibase"
PIPELINE_GATE="enforce-pipeline-order"
DEV_GREEN_GATE="dev-all-green"

apply_protection() {
  local branch="$1"
  shift
  # Extra required status check contexts for this specific branch.
  # pre-staging additionally requires `dev-all-green` (set by
  # scripts/dev/merge after it verifies all push-event CI on dev tip
  # is passing) so even a hand-opened PR can't slip in red CI.
  local -a extra_contexts=("$@")

  echo "Configuring protection on $branch..."
  # GitHub's branch protection API. Key bits:
  #   * required_status_checks.strict=false (PR doesn't need to be
  #     rebased on latest target — we allow stale-but-passing checks
  #     to merge; this lets auto-merge work cleanly).
  #   * required_status_checks.contexts includes our PR-gate plus any
  #     branch-specific extras.
  #   * required_pull_request_reviews=null (no human review required —
  #     the pipeline itself is the gate).
  #   * restrictions=null (no per-user/team push restriction beyond
  #     the PR rule).
  #   * allow_force_pushes=false / allow_deletions=false (safety).
  #   * required_linear_history=false (staging-promote opens merge
  #     commits; don't break it).
  # Use -F (typed) rather than -f (string) so the strict/contexts
  # values land in the JSON as boolean/array correctly. Some older
  # gh CLI versions only accept arrays via -F here.
  local -a ctx_args=("-F" "required_status_checks[contexts][]=$PIPELINE_GATE")
  for c in "${extra_contexts[@]}"; do
    ctx_args+=("-F" "required_status_checks[contexts][]=$c")
  done

  gh api -X PUT "repos/$REPO/branches/$branch/protection" \
    -H "Accept: application/vnd.github+json" \
    -F enforce_admins=false \
    -F required_pull_request_reviews=null \
    -F restrictions=null \
    -F allow_force_pushes=false \
    -F allow_deletions=false \
    -F required_linear_history=false \
    -F lock_branch=false \
    -F allow_fork_syncing=false \
    -F required_conversation_resolution=false \
    -F "required_status_checks[strict]=false" \
    "${ctx_args[@]}" \
    >/dev/null

  local extra_msg=""
  [ ${#extra_contexts[@]} -gt 0 ] && extra_msg=" + extra: ${extra_contexts[*]}"
  echo "  ✓ $branch protected (PR Gate required$extra_msg, no human review, no force-push, no delete)"
}

# main and staging: only enforce-pipeline-order (the structural head-ref check).
# pre-staging: also require dev-all-green (set by scripts/dev/merge).
apply_protection main
apply_protection staging
apply_protection pre-staging "$DEV_GREEN_GATE"

echo
echo "Done. Verify with:"
echo "  gh api repos/$REPO/branches/main/protection | jq ."
echo
echo "Note: 'dev' is intentionally NOT protected — direct push is OK there"
echo "since it is the work branch (no automation depends on dev's tip"
echo "being via PR)."
