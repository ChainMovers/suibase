#!/bin/bash

# This script is only intended for developers and continuous integration.
#
# It forces a Rust rebuild of the "localnet-tools" binaries (today:
# walrus-localnet-deploy, from rust/walrus-store) and reinstalls them into
# workdirs/common/bin. Precompiled binaries are NOT used.
#
# Mirrors scripts/dev/update-daemon for the localnet-tools asset, so the two
# follow one consistent pattern (source build on a dev branch / via this command;
# precompiled download on main/staging — see sb_app_install in __apps.sh).

SUIBASE_DIR="$HOME/suibase"
WORKDIR="none"

# shellcheck source=SCRIPTDIR/../common/__globals.sh
source "$SUIBASE_DIR/scripts/common/__globals.sh" "$SCRIPT_COMMON_CALLER" "$WORKDIR"
trap cleanup EXIT

# shellcheck source=SCRIPTDIR/../common/__apps.sh
source "$SUIBASE_DIR/scripts/common/__apps.sh"

exit_if_not_installed
exit_if_deps_missing

# Force a rebuild: delete the installed binary + version file so the install is
# unconditional. (cargo still does an incremental compile — only changed sources.)
rm -f "$SUIBASE_BIN_DIR/walrus-localnet-deploy" \
  "$SUIBASE_BIN_DIR/localnet-tools-version.yaml"

# Build + install from source (rust/walrus-store, localnet feature).
init_app_obj "localnet_tools" ""

_BUILD_START_TIME=$SECONDS
sb_app_rust_build_and_install_generic "localnet_tools"
_BUILD_END_TIME=$SECONDS

_BUILD_DURATION=$((_BUILD_END_TIME - _BUILD_START_TIME))
echo "✓ localnet-tools rebuilt in ${_BUILD_DURATION}s -> $SUIBASE_BIN_DIR/walrus-localnet-deploy"
