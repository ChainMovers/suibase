#!/bin/bash

# Merge `dev` into `pre-staging` — the entry point of the release pipeline.
#
#   dev ──(this script)──► pre-staging ──cron→ staging → main
#
# This is the DX command that turns work on `dev` into a release.
# Everything past `pre-staging` is automated:
#
#   * pre-staging.yml — pushes Cargo.toml to chainmovers/sui-binaries if
#     a matching daemon release tag doesn't already exist; no tests.
#   * staging-promote.yml (cron) — opens auto-merge PR pre-staging →
#     staging once the binary tag is published.
#   * staging.yml — validates precompiled, then auto-PRs to main.
#
# So the only manual step in normal operation is running this script.
#
# The fastidious merge-hook from the previous (single-branch-to-main)
# model is intentionally NOT invoked here. The pipeline now enforces
# the binary-vs-source version match via the staging.yml validation
# stage; the merge-hook's role of "do not merge without a published
# precompiled" is now performed by staging-promote.yml's cron-poll
# (which only promotes when the tag exists). Re-invoking the hook
# here would block every pre-staging merge whose Cargo.toml version
# is ahead of sui-binaries — which is the EXPECTED state.
#
# Exit immediately if a command exits with a non-zero status.

set -e

# Switch to dev branch if not already on it.
current_branch=$(git rev-parse --abbrev-ref HEAD)
if [ "$current_branch" != "dev" ]; then
  echo "Switching to dev branch"
  git checkout dev
fi

# Make sure the dev branch does not have uncommitted changes.
if ! git diff-index --quiet HEAD --; then
  echo "Uncommitted changes in the dev branch. Please commit or stash them before merging."
  echo
  echo "===================================="
  echo "  ✗ NO MERGE INTO PRE-STAGING"
  echo "    Reason: uncommitted changes on dev"
  echo "===================================="
  exit 1
fi

# Make sure the dev branch is up-to-date with the remote.
git fetch origin dev
if [ "$(git rev-parse dev)" != "$(git rev-parse origin/dev)" ]; then
  echo "dev branch not up-to-date with remote. Do 'git push'."
  echo
  echo "===================================="
  echo "  ✗ NO MERGE INTO PRE-STAGING"
  echo "    Reason: local dev != origin/dev"
  echo "===================================="
  exit 1
fi

# Call sync to verify dev is current with main/pre-staging/staging.
# Catches any back-merges (which should be rare under the pipeline
# model but are possible in emergencies).
# shellcheck source=./sync
source "$HOME/suibase/scripts/dev/sync"

# Promote dev → pre-staging via auto-merge PR.
#
# Branch protection on pre-staging requires PRs (no direct push), so we
# open one and immediately enable auto-merge. With matching tips this is
# essentially instant; with the pr-gate check it's also instant
# (head_ref == dev satisfies the gate). Required: `gh` CLI authenticated.
git fetch origin pre-staging

# Check if there are any changes from dev that are not in pre-staging.
if git merge-base --is-ancestor dev origin/pre-staging; then
  echo
  echo "===================================="
  echo "  ⊘ NO MERGE INTO PRE-STAGING"
  echo "    Reason: pre-staging already contains dev's tip"
  echo "    (nothing new to promote — this is normal if you just ran"
  echo "    merge a moment ago, or if you haven't pushed new commits)"
  echo "===================================="
  exit 0
fi

# Verify ALL push-event CI workflows on dev's tip are green BEFORE
# letting the change escape into the release pipeline. This catches
# the "dev had a red badge but I ran merge anyway" mistake.
#
# In-flight runs are treated as "wait" not "OK": if any workflow is
# still in_progress/queued, the script aborts and asks you to re-run
# once CI completes. Avoids the racy "merge fired while CI was still
# running" case.
#
# On success, sets a `dev-all-green` commit status on dev's tip which
# branch protection on pre-staging requires (belt + suspenders so
# even if someone bypasses this script, the merge still can't go
# through without all CI being green at dev's tip).
DEV_SHA=$(git rev-parse origin/dev)
echo
echo "Verifying dev@${DEV_SHA:0:10} is all-green before promoting..."

# Workflows that ALL must be green on a dev push for a promotion to
# be allowed. Lint covers syntax; the four matrices cover code.
REQUIRED_WORKFLOWS=(
  "Lint"
  "Suibase Daemon Tests"
  "Rust Tests"
  "TypeScript Tests"
  "Scripts Tests"
)

any_failed=false
any_running=false
for w in "${REQUIRED_WORKFLOWS[@]}"; do
  # Look for the run for THIS exact dev SHA (not just latest on dev).
  result=$(gh run list --commit "$DEV_SHA" --workflow "$w" --limit 1 \
    --json status,conclusion --jq '.[0] | "\(.status // "no-run")/\(.conclusion // "—")"' 2>/dev/null)
  case "$result" in
    "completed/success")
      printf "  ✓ %s\n" "$w"
      ;;
    "completed/skipped"|"completed/neutral")
      printf "  ⊘ %s (skipped — no relevant diff)\n" "$w"
      ;;
    "in_progress/—"|"queued/—"|"waiting/—"|"requested/—"|"pending/—")
      printf "  ⏳ %s still running\n" "$w"
      any_running=true
      ;;
    "completed/failure"|"completed/cancelled"|"completed/timed_out"|"completed/action_required")
      printf "  ✗ %s: %s\n" "$w" "$result"
      any_failed=true
      ;;
    "no-run/—")
      printf "  ✗ %s: no run found for dev@${DEV_SHA:0:10}\n" "$w"
      any_failed=true
      ;;
    *)
      printf "  ? %s: %s\n" "$w" "$result"
      any_failed=true
      ;;
  esac
done

if $any_failed; then
  echo
  echo "===================================="
  echo "  ✗ NO MERGE INTO PRE-STAGING"
  echo "    Reason: some dev CI workflows are RED (or no run found)"
  echo "    Fix the failing tests, push, and re-run."
  echo "    Check at: https://github.com/ChainMovers/suibase/actions?query=branch%3Adev"
  echo "===================================="
  exit 1
fi
if $any_running; then
  echo
  echo "===================================="
  echo "  ✗ NO MERGE INTO PRE-STAGING"
  echo "    Reason: CI on dev tip is still RUNNING"
  echo "    Wait for CI to complete, then re-run."
  echo "    Check at: https://github.com/ChainMovers/suibase/actions?query=branch%3Adev"
  echo "===================================="
  exit 1
fi

echo "  → all green ✓"

# Set the dev-all-green commit status so branch protection on
# pre-staging is satisfied. The status name MUST match the required
# context configured by scripts/dev/apply-branch-protection.
gh api -X POST "repos/ChainMovers/suibase/statuses/$DEV_SHA" \
  -f state=success \
  -f context=dev-all-green \
  -f description="All dev push-event CI workflows passed (set by scripts/dev/merge)" \
  >/dev/null

# Reuse an open PR if one exists; otherwise open one.
existing=$(gh pr list --base pre-staging --head dev --state open --json number --jq '.[0].number')
if [ -z "$existing" ]; then
  version=$(awk -F'"' '/^version[[:space:]]*=/{print $2; exit}' rust/suibase/Cargo.toml 2>/dev/null)
  title="Promote dev to pre-staging"
  [ -n "$version" ] && title="$title (suibase-daemon v$version)"
  gh pr create --base pre-staging --head dev \
    --title "$title" \
    --body "Auto-opened by \`scripts/dev/merge\`. The pipeline (pre-staging.yml → cron → staging.yml) carries it through to main. See CONTRIBUTING.md."
  existing=$(gh pr list --base pre-staging --head dev --state open --json number --jq '.[0].number')
fi
echo
echo "===================================="
echo "  ✓ MERGING INTO PRE-STAGING"
echo "    PR #$existing dev → pre-staging (auto-merge enabled)"
echo "    Pipeline will carry it: pre-staging → staging → main → deploy-docs"
echo "===================================="
gh pr merge "$existing" --auto --merge

# Trigger the cron immediately instead of waiting up to 15 min for the
# next scheduled tick. Saves a chunk of pipeline latency. Cron is safe
# to dispatch even if the PR hasn't finished merging yet — it exits
# silent ("nothing to promote") if pre-staging isn't ahead of staging,
# and exits silent ("waiting on sui-binaries") if the matching daemon
# release tag isn't published yet. So the worst case of an early
# dispatch is "one cron run that does nothing"; the regular 15-min
# cron + the post-merge dispatch in staging-promote.yml itself still
# catch any case we miss.
#
# Poll for the PR to reach MERGED first when possible, so the cron
# sees the new pre-staging tip on its first try. Bounded — if the
# merge takes longer than 60s, dispatch anyway and let the cron retry
# logic do its thing.
echo "Waiting for PR #$existing to reach MERGED state (then dispatching cron)..."
for i in $(seq 1 12); do
  state=$(gh pr view "$existing" --json state --jq .state 2>/dev/null)
  if [ "$state" = "MERGED" ]; then
    echo "PR #$existing merged — dispatching staging-promote.yml now (skips up to 15-min cron wait)."
    gh workflow run staging-promote.yml --ref main || \
      echo "(cron dispatch failed — the regular 15-min schedule will still catch this)"
    exit 0
  fi
  sleep 5
done
echo "PR #$existing didn't reach MERGED in 60s — dispatching cron anyway."
gh workflow run staging-promote.yml --ref main || \
  echo "(cron dispatch failed — the regular 15-min schedule will still catch this)"
